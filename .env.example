# SubstituteRx is local-only by design. The only network endpoint the application
# touches is the configured Ollama host. No cloud LLM API keys are required or used —
# the codebase ships with no cloud provider client (see src/substituterx/provider.py
# and tests/test_local_only.py for the enforced contract).

OLLAMA_HOST=http://localhost:11434

# Provider selection: auto (probe Ollama → fall back to mock) | ollama | mock
SUBSTITUTERX_PROVIDER=auto

# Per-agent model overrides. Recommended hybrid configuration:
SUBSTITUTERX_MODEL_REASONER=medgemma1.5:4b-it-q8_0
SUBSTITUTERX_MODEL_VALIDATOR=medgemma1.5:4b-it-q8_0
SUBSTITUTERX_MODEL_AUDITOR=qwen3:14b-q8_0

SUBSTITUTERX_DB_PATH=./data/kg.duckdb
SUBSTITUTERX_AUDIT_LOG=./audit_logs/audit.jsonl
SUBSTITUTERX_LOG_LEVEL=INFO
