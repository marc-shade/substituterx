# Pick one provider path; the agent layer is provider-agnostic.
ANTHROPIC_API_KEY=
# or
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Local fallback (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

SUBSTITUTERX_DB_PATH=./data/kg.duckdb
SUBSTITUTERX_AUDIT_LOG=./audit_logs/audit.jsonl
SUBSTITUTERX_LOG_LEVEL=INFO
